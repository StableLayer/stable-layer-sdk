{
  "name": "stable-layer-sdk",
  "version": "3.1.0",
  "description": "A TypeScript SDK for Stable Layer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StableLayer/stable-layer-sdk"
  },
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.cjs",
      "import": "./dist/esm/index.mjs",
      "default": "./dist/esm/index.mjs"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "require": "./dist/cjs/*.cjs",
      "import": "./dist/esm/*.mjs",
      "default": "./dist/esm/*.mjs"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf tsconfig.tsbuildinfo ./dist",
    "build": "pnpm run build:esbuild && pnpm run build:types",
    "build:esbuild": "node build.js",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:e2e:testnet": "vitest run --config vitest.e2e-testnet.config.ts",
    "query-output": "QUERY_OUTPUT=1 vitest run",
    "sl:mint": "node ./scripts/sl-mint.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "sdk",
    "stable-layer",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@mysten/bcs": "^2.0.0",
    "@mysten/sui": "^2.5.0",
    "@tsconfig/recommended": "^1.0.3",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.0.0",
    "vitest": "^4.0.7"
  },
  "dependencies": {
    "@bucket-protocol/sdk": "^2.1.0"
  },
  "peerDependencies": {
    "@mysten/bcs": ">=2.0.0",
    "@mysten/sui": ">=2.0.0"
  }
}
